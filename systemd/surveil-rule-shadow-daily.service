[Unit]
Description=Surveil daily rule comparison review
After=network-online.target surveil-db-init.service
Wants=network-online.target

[Service]
Type=oneshot
User=surveil
WorkingDirectory=/opt/surveil
EnvironmentFile=-/opt/surveil/.env
ExecStart=/opt/surveil/.venv/bin/python /opt/surveil/scripts/rule_core_shadow_daily.py
StandardOutput=append:/opt/surveil/logs/rule-shadow-daily.log
StandardError=append:/opt/surveil/logs/rule-shadow-daily.err.log
