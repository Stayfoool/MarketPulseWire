# 复制本文件为 .env，然后把右侧替换成你自己的真实值。
# 不要把 .env 发到聊天里，也不要提交到 git。

# X / Twitter API
X_USERNAME=
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_REDIRECT_URI=http://127.0.0.1:8765/callback

# Feishu custom bot，后续接飞书时填写
FEISHU_WEBHOOK=
FEISHU_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 通用 LLM 配置。后续切换模型供应商时，优先改这三项。
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# 模型响应较慢或网络抖动时可调大。生产默认：timeout 90 秒、失败重试 2 次。
LLM_TIMEOUT_SECONDS=90
LLM_RETRY_COUNT=2
LLM_RETRY_SLEEP_SECONDS=2
# DeepSeek 默认自动启用 OpenAI-compatible JSON mode，减少 flash 模型输出坏 JSON。
# 如果某个兼容供应商不支持 response_format，可设为 0。
LLM_RESPONSE_FORMAT_JSON=

# 价值目录：读取用户正常登录可见的列表页和详情页第一页预览图，不下载 PDF。
# 启用两个子来源：国际投行-个股、国际投行-行业宏观。
VALUE_DIRECTORY_SOURCES=value_directory_ib_stocks,value_directory_ib_industry_macro
VALUE_DIRECTORY_PREVIEW_ENABLED=1
# 默认用本地 PaddleOCR 读取第一页图片文字，再交给文本 LLM 提取结构化字段；不需要 GPU 或外部 OCR API。
VALUE_DIRECTORY_PREVIEW_OCR_ENABLED=1
VALUE_DIRECTORY_PREVIEW_OCR_LANG=ch
VALUE_DIRECTORY_PREVIEW_OCR_MIN_CHARS=40
VALUE_DIRECTORY_PREVIEW_LLM_ENABLED=1
# 默认复用 LLM_*；OCR 后走文本模型即可。DeepSeek 会沿用全局的 JSON/禁用 thinking 策略。
# 只有显式开启视觉兜底时才需要支持 image_url 的模型。
VALUE_DIRECTORY_PREVIEW_API_KEY=
VALUE_DIRECTORY_PREVIEW_BASE_URL=
VALUE_DIRECTORY_PREVIEW_MODEL=
VALUE_DIRECTORY_PREVIEW_LLM_TIMEOUT_SECONDS=45
VALUE_DIRECTORY_PREVIEW_LLM_RETRY_COUNT=1
VALUE_DIRECTORY_PREVIEW_VISION_FALLBACK_ENABLED=0
# 1：硬规则命中但第一页提取失败时仍发送提醒，并明确标注失败；0：由最终 DecisionResult.action 归档，只入库不推。
VALUE_DIRECTORY_PUSH_ON_PREVIEW_FAILURE=1
# 价值目录每日运行时，顺手复核当前列表中尚未推送的旧 review，便于新规则/新持仓关键词生效。
VALUE_DIRECTORY_RECHECK_UNPUSHED=1
VALUE_DIRECTORY_RECHECK_UNPUSHED_LIMIT=30
VALUE_DIRECTORY_BROWSER_TIMEOUT_MS=45000

# OpenAI-compatible 兼容别名。程序优先读取 LLM_*，为空时再读取 OPENAI_*。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# 等价可选写法：如果你更想按阿里云命名，也可以填 DASHSCOPE_*。
# 程序优先读取 LLM_* / OPENAI_*，为空时再读取 DASHSCOPE_*。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
DASHSCOPE_MODEL=

# 持仓监控方案：本地/远程服务器 + 新浪财经快讯 + iFinD 公告 + OpenAI-compatible LLM
# 新闻来源：
# - legacy：新浪公开快讯/个股页，当前默认路径，不消耗新浪智研付费 API。
# - zy_api：新浪财经智研平台 OpenAPI 直连，可选付费路径。
# - zy_mcp：新浪财经智研平台 MCP/HTTP，可选备用/验证通道。
SINA_NEWS_PROVIDER=legacy
SINA_ZY_API_KEY=
# OpenAPI 直连地址需要从新浪智研登录后的接口详情页确认后填写。
SINA_ZY_API_BASE_URL=
# MCP 仅作为备用/验证通道。
SINA_ZY_MCP_URL=http://mcp.finance.sina.com.cn/mcp-http
SINA_ZY_TIMEOUT_SECONDS=20
SINA_FLASH_POLL_SECONDS=15
SINA_FLASH_TAGS=10
SINA_FLASH_PAGE_SIZE=20
SINA_FLASH_VERBOSE=
PORTFOLIO_IMPORTANCE_THRESHOLD=medium
MARKET_SKILL_DIR=
SKEPTIC_EVALUATOR_ENABLED=1
SKEPTIC_STALE_NEWS_DAYS=7
SKEPTIC_DUPLICATE_LOOKBACK_DAYS=14
SOURCE_HEALTH_ALERT_FAILURES=3
SOURCE_HEALTH_ALERT_COOLDOWN_MINUTES=60
SOURCE_HEALTH_ALERT_RECOVERY=1
# 公开 RSS/RSSHub 源被 429/503 限流或服务异常后，单源临时冷却，减少重复失败和告警抖动。
SOURCE_BACKOFF_SEMIANALYSIS_SECONDS=1800
SOURCE_BACKOFF_JIN10_SECONDS=600
SOURCE_BACKOFF_DEFAULT_SECONDS=0
LLM_SKEPTIC_THINKING_TYPE=enabled
LLM_SKEPTIC_MAX_OUTPUT_TOKENS=1200
# 新闻媒体明确转述受信任行业研究源时，仅对复杂语义运行受限结构化抽取。
# 模型不能输出 importance/action，最终推送仍由确定性规则决定。
ATTRIBUTED_RESEARCH_LLM_ENABLED=1
ATTRIBUTED_RESEARCH_LLM_THINKING_TYPE=disabled
ATTRIBUTED_RESEARCH_LLM_MAX_OUTPUT_TOKENS=900
# Optional controlled web evidence retrieval for Skeptic Evaluator.
# Default off. Configure via Web workbench or uncomment/fill these values.
WEB_EVIDENCE_ENABLED=0
WEB_EVIDENCE_PROVIDER=tavily
WEB_EVIDENCE_API_KEY=
WEB_EVIDENCE_MODE=realtime
WEB_EVIDENCE_MAX_QUERIES=5
WEB_EVIDENCE_MAX_RESULTS=4
WEB_EVIDENCE_LOOKBACK_DAYS=30
WEB_EVIDENCE_TIMEOUT_SECONDS=12
WEB_EVIDENCE_FETCH_BODY=0
WEB_EVIDENCE_TAVILY_SEARCH_DEPTH=basic
WEB_EVIDENCE_TAVILY_TOPIC=news
IFIND_NOTICE_RUN_TIMES=08:00,20:00
IFIND_API_BASE_URL=
# iFinD REST 用 Refresh Token 换 Access Token；推荐填写这个变量。
# 注意：这不是新版“密钥 / 个人令牌 / API 密钥”。
IFIND_REFRESH_TOKEN=
# 可选：如果账号详情页能直接复制 Access Token，也可以临时填写这个做连通性测试。
IFIND_ACCESS_TOKEN=
# 兼容旧命名。如果同时填写，程序应优先使用 IFIND_REFRESH_TOKEN。
IFIND_API_KEY=
IFIND_ACCOUNT=
IFIND_PASSWORD=
# iFinD 公告 PDF 正文解析。默认启用，在部署服务器本地下载 PDF 并用 pypdf 抽取文本。
IFIND_NOTICE_PDF_PARSE=1
IFIND_NOTICE_PDF_DIR=data/ifind_notices
IFIND_NOTICE_PDF_MAX_BYTES=31457280
IFIND_NOTICE_PDF_MAX_PAGES=80
IFIND_NOTICE_TEXT_MAX_CHARS=20000
IFIND_NOTICE_TEXT_MIN_CHARS=200
# 韭研公社低频异动解析。若官方接口提示登录失效，可把浏览器中本账号正常登录态 cookie 写到这里。
# 不配置时脚本仍会按官方公开接口尝试；遇到登录失效/请求异常会安全跳过。
JYGS_COOKIE=
# 如果只想保存 SESSION 值，也可以填 JYGS_SESSION，脚本会拼成 Cookie: SESSION=...
JYGS_SESSION=
# 韭研接口签名参数。仅在你确认自己有权使用该接口时，写入私有 .env；不要提交到 git。
JYGS_SIGN_SECRET=
# 调试时设为 1，会输出脱敏后的请求/响应元数据，不输出 cookie/token 明文。
JYGS_API_DEBUG=
JYGS_PAGE_LIMIT=30
JYGS_MAX_FETCH_ITEMS=300
REMOTE_HOST=your.server.example.com
REMOTE_USER=root
REMOTE_SSH_KEY=~/.ssh/id_ed25519
REMOTE_DIR=/opt/surveil
REMOTE_PROXY_DIR=/opt/surveil-proxy
REMOTE_SERVICE_USER=surveil

# 可选：禁用 LLM，强制回退规则分析
SURVEIL_DISABLE_LLM=

# 监控调节
# 设为 1 时，新来源首次建立基线也会把旧条目发送到飞书。默认留空，避免刷屏。
SURVEIL_NOTIFY_BASELINE=
TRENDFORCE_PAGE_INTERVAL=900
